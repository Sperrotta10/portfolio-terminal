---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Command from "../../components/Command.astro";
import Section from "../../components/Section.astro";

export async function getStaticPaths() {
  const projectEntries = await getCollection("projects");
  return projectEntries.map((entry: any) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} — Documentation`}
  description={entry.data.description}
>
  <main class="container">
    <div class="window doc-window">
      <div class="titlebar">
        <div class="flex gap-2 items-center">
          <a href="/" class="dot dot-close" title="Volver al inicio"></a>
          <span class="dot dot-min"></span>
          <span class="dot dot-max"></span>
        </div>
        <div class="title">
          docs — {entry.id}.md <a href="/" class="back-link">cd ../</a>
        </div>
      </div>

      <div class="content">
        <Command command={`view projects/${entry.id}.md`} variant="title" />

        <Section>
          <article class="markdown-body">
            <header class="doc-header">
              <h1>{entry.data.title}</h1>
              <p class="subtitle">{entry.data.description}</p>
              {
                entry.data.tech && (
                  <div class="tech-stack">
                    {entry.data.tech.map((t: any) => (
                      <span class="t-badge">{t}</span>
                    ))}
                  </div>
                )
              }
            </header>

            <div class="separator"></div>

            <div class="prose">
              <Content />
            </div>
          </article>
        </Section>

        <div class="separator"></div>

        <div class="doc-footer">
          <p>
            Fin de la documentación. <a href="/" class="highlight-link"
              >Volver al terminal</a
            >
          </p>
        </div>
      </div>

      <div class="status-bar">
        <div class="flex gap-3">
          <span class="status-item mode doc">READONLY</span>
          <span class="status-item file">{entry.id}.md</span>
        </div>
        <div class="flex gap-3">
          <span class="status-item">UTF-8</span>
          <span class="status-item">Markdown</span>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .doc-window {
    max-width: 900px;
    margin: 40px auto;
    border: 1px solid var(--color-surface-high);
  }

  .window {
    background: linear-gradient(
      180deg,
      var(--color-surface-lowest),
      var(--color-bg)
    );
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .titlebar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 44px;
    background: var(--color-surface-low);
    border-bottom: 1px solid var(--color-surface-high);
    padding: 0 16px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.35);
    display: inline-block;
  }
  .dot-close {
    background: #ff5f57;
    cursor: pointer;
  }
  .dot-min {
    background: #febc2e;
  }
  .dot-max {
    background: #28c840;
  }

  .title {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    font-family: var(--font-code);
  }

  .back-link {
    color: var(--color-accent);
    text-decoration: none;
    font-family: var(--font-code);
    font-size: 12px;
    justify-self: end;
  }
  .back-link:hover {
    text-decoration: underline;
  }

  .content {
    padding: 24px;
  }

  /* Remove internal scrollbar styling since we now use page scroll */

  .doc-header h1 {
    font-family: var(--font-ui);
    font-size: 2.5rem;
    color: var(--color-accent);
    margin: 0;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    margin: 8px 0 16px 0;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .t-badge {
    background: rgba(129, 230, 217, 0.1);
    color: var(--color-accent);
    padding: 2px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-family: var(--font-code);
    border: 1px solid rgba(129, 230, 217, 0.2);
  }

  .separator {
    height: 1px;
    margin: 32px 0;
    background: linear-gradient(
      90deg,
      rgba(129, 230, 217, 0),
      rgba(129, 230, 217, 0.3),
      rgba(129, 230, 217, 0)
    );
  }

  /* Prose / Markdown Styling */
  .prose {
    color: var(--color-text);
    font-family: var(--font-ui);
    line-height: 1.8;
    font-size: 16px;
  }

  .prose :global(h2) {
    color: var(--color-accent);
    font-size: 1.8rem;
    margin: 2rem 0 1rem 0;
    border-bottom: 1px solid var(--color-surface-high);
    padding-bottom: 0.5rem;
  }

  .prose :global(h3) {
    color: var(--color-text);
    font-size: 1.4rem;
    margin: 1.5rem 0 1rem 0;
  }

  .prose :global(p) {
    margin-bottom: 1.2rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.2rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(code) {
    background: var(--color-surface-low);
    color: var(--color-accent-strong);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: var(--font-code);
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--color-surface-lowest);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--color-surface-high);
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--color-text);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 2rem 0;
    border: 1px solid var(--color-surface-high);
  }

  .doc-footer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 14px;
    font-family: var(--font-code);
  }

  .highlight-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: bold;
  }
  .highlight-link:hover {
    text-decoration: underline;
  }

  .status-bar {
    position: sticky;
    bottom: 0;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    background: var(--color-surface-low);
    border-top: 1px solid var(--color-surface-high);
    padding: 4px 12px;
    font-family: var(--font-code);
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .status-item {
    display: flex;
    align-items: center;
  }

  .status-item.mode.doc {
    background: var(--color-warning);
    color: var(--color-bg);
    padding: 0 6px;
    font-weight: bold;
  }

  @media (max-width: 600px) {
    .doc-window {
      margin: 0;
      border: none;
      min-height: 100vh;
      max-width: 100%;
    }
    .content {
      max-height: none;
    }
  }
</style>
