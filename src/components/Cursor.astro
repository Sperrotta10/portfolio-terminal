---
export interface Props {
  variant?: "block" | "bar" | "underscore";
  class?: string;
}

const { variant = "block", class: className } = Astro.props;
const char = variant === "underscore" ? "_" : variant === "bar" ? "|" : "█";
---

<span class={`cursor ${className ?? ""}`} aria-hidden="true">{char}</span>

<style>
  .cursor {
    display: inline-block;
    color: var(--accent);
    font-family: var(--font-code);
    line-height: 1;
    transform: translateY(1px);
    animation: blink 1.1s steps(1, end) infinite;
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
</style>
