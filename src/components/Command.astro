---
import Cursor from "./Cursor.astro";

export interface Props {
  prompt?: string;
  command: string;
  showCursor?: boolean;
  variant?: "normal" | "title";
}

const { prompt = "$", command, showCursor = false, variant = "normal" } = Astro.props;
---

<div class={`command ${variant === "title" ? "is-title" : ""}`}>
  <span class="prompt">{prompt}</span>
  <span class="cmd-wrapper">
    <span class="cmd">{command}</span>
  </span>
  {showCursor ? <Cursor /> : null}
</div>

<style>
  .command {
    display: flex;
    gap: 8px;
    align-items: baseline;
    color: var(--color-text);
    font-family: var(--font-code);
    font-size: 13px;
    line-height: 1.65;
    white-space: pre-wrap;
  }

  @media (min-width: 520px) {
    .command { font-size: 14px; }
  }

  .command.is-title {
    margin-top: 24px;
    font-size: 16px;
    line-height: 1.6;
  }

  @media (min-width: 520px) {
    .command.is-title { font-size: 20px; }
  }

  .prompt {
    color: var(--color-accent);
    user-select: none;
  }

  .cmd-wrapper {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    animation: typing 1.5s steps(40, end) forwards;
  }

  .cmd { color: var(--color-text); }

  .command.is-title .cmd {
    color: var(--color-accent-strong);
    font-weight: 600;
  }
</style>
