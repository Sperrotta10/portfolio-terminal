---
export interface Props {
  tone?: "normal" | "muted" | "accent";
}

const { tone = "normal" } = Astro.props;
---

<section class={`section tone-${tone}`}>
  <slot />
</section>

<style>
  .section {
    margin-top: 16px;
    padding-left: 12px;
    border-left: 2px solid rgba(129, 230, 217, 0.5);
  }

  @media (min-width: 520px) {
    .section { padding-left: 16px; }
  }

  .tone-normal { color: var(--color-text); }
  .tone-muted  { color: var(--color-text-muted); }
  .tone-accent { color: var(--color-accent-strong); }
</style>
